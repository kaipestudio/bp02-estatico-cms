---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const postsOrdenados = posts.sort((a, b) => 
  new Date(b.data.date) - new Date(a.data.date)
);
---

<Layout title="Blog | Minha Agência">
  <section class="max-w-4xl mx-auto py-12">
    <h1 class="text-4xl font-bold text-center mb-12">Blog</h1>
    
    {postsOrdenados.length > 0 ? (
      <div class="space-y-8">
        {postsOrdenados.map((post) => {
          const slug = post.id.replace(/\.md$/, '');
          return (
            <article class="bg-white p-6 rounded-xl shadow-lg hover:shadow-xl transition">
              <a href={`/blog/${slug}`} class="block">
                <h2 class="text-2xl font-bold text-blue-600 hover:underline">
                  {post.data.title}
                </h2>
                <time class="text-sm text-gray-500">
                  {new Date(post.data.date).toLocaleDateString('pt-BR')}
                </time>
                {post.data.description && (
                  <p class="mt-2 text-gray-600">{post.data.description}</p>
                )}
              </a>
            </article>
          );
        })}
      </div>
    ) : (
      <div class="text-center bg-white p-12 rounded-xl shadow-lg">
        <p class="text-gray-600">Nenhum post encontrado.</p>
        <a href="/admin" class="text-blue-600 hover:underline">Criar primeiro post</a>
      </div>
    )}
  </section>
</Layout>