---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const servicos = await getCollection('servicos');
const servicosOrdenados = servicos.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
---

<Layout title="Home | Minha Agência">
  <!-- Hero -->
  <section class="text-center py-16 space-y-6">
    <h1 class="text-5xl md:text-6xl font-bold text-gray-900">
      Transformamos ideias em<br />
      <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
        realidade digital
      </span>
    </h1>
    <p class="text-xl text-gray-600 max-w-2xl mx-auto">
      Soluções criativas e tecnológicas para sua marca se destacar no mundo digital
    </p>
    <div class="flex justify-center gap-4 flex-wrap">
      <a 
        href="/blog" 
        class="bg-blue-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-blue-700 transition"
      >
        📝 Ver Blog
      </a>
      <a 
        href="/admin" 
        class="bg-gray-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-gray-700 transition"
      >
        ⚙️ Gerenciar CMS
      </a>
    </div>
  </section>

  <!-- Serviços -->
  <section class="py-12">
    <h2 class="text-3xl font-bold text-center mb-8">Nossos Serviços</h2>
    
    {servicosOrdenados.length > 0 ? (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {servicosOrdenados.map((servico) => (
          <div class="bg-white p-6 rounded-xl shadow-lg hover:shadow-xl transition">
            <div class="text-4xl mb-3">{servico.data.icon || '🚀'}</div>
            <h3 class="text-xl font-bold mb-2">{servico.data.title}</h3>
            <p class="text-gray-600">{servico.data.description}</p>
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center bg-white p-8 rounded-xl shadow-lg max-w-md mx-auto">
        <p class="text-gray-600">Nenhum serviço cadastrado.</p>
        <a href="/admin" class="text-blue-600 hover:underline">Adicionar serviços</a>
      </div>
    )}
  </section>
</Layout>