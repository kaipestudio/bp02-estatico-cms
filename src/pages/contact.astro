---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contato | Minha Agência">
  <section class="max-w-4xl mx-auto py-12">
    <h1 class="text-4xl font-bold text-gray-900 text-center mb-8">Entre em Contato</h1>
    
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Informações de contato -->
      <div class="space-y-6">
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
          <h3 class="text-lg font-semibold mb-2">📧 E-mail</h3>
          <a href="mailto:contato@meusite.com" class="text-blue-600 hover:underline">
            contato@meusite.com
          </a>
        </div>
        
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
          <h3 class="text-lg font-semibold mb-2">📱 Telefone</h3>
          <p class="text-gray-600">(11) 99999-9999</p>
        </div>
        
        <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
          <h3 class="text-lg font-semibold mb-2">📍 Endereço</h3>
          <p class="text-gray-600">
            Av. Paulista, 1000<br />
            São Paulo - SP, 01310-100
          </p>
        </div>
      </div>
      
      <!-- Formulário -->
      <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
        <h3 class="text-lg font-semibold mb-4">Envie uma mensagem</h3>
        
        <form class="space-y-4" netlify>
          <div>
            <label for="nome" class="block text-sm font-medium text-gray-700 mb-1">
              Nome
            </label>
            <input 
              type="text" 
              id="nome" 
              name="nome"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition"
              placeholder="Seu nome completo"
              required
            />
          </div>
          
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
              E-mail
            </label>
            <input 
              type="email" 
              id="email" 
              name="email"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition"
              placeholder="seu@email.com"
              required
            />
          </div>
          
          <div>
            <label for="mensagem" class="block text-sm font-medium text-gray-700 mb-1">
              Mensagem
            </label>
            <textarea 
              id="mensagem" 
              name="mensagem"
              rows="4" 
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition"
              placeholder="Sua mensagem..."
              required
            ></textarea>
          </div>
          
          <button 
            type="submit" 
            class="w-full bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition"
          >
            Enviar mensagem
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>